<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>File Sharing Server</title>
    <style>
      body {
        font-family: Segoe UI, Arial, sans-serif;
        background: #f2f4f7;
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
      }
      .card {
        width: min(560px, 92vw);
        background: #fff;
        border-radius: 10px;
        padding: 1.25rem;
        box-shadow: 0 8px 28px rgba(0, 0, 0, 0.08);
      }
      h1 {
        margin-top: 0;
      }
      form {
        display: grid;
        gap: 0.75rem;
      }
      input,
      button {
        font-size: 1rem;
        padding: 0.6rem;
      }
      button {
        cursor: pointer;
      }
      .error {
        color: #b42318;
      }
      .link-box {
        margin-top: 1rem;
        padding: 0.75rem;
        border: 1px solid #d0d5dd;
        border-radius: 8px;
        word-break: break-all;
      }
      .link-actions {
        margin-top: 0.75rem;
        display: flex;
        gap: 0.5rem;
        align-items: center;
      }
      .copy-status {
        font-size: 0.9rem;
        color: #475467;
      }
      .footer {
        margin-top: 1rem;
        font-size: 0.9rem;
        color: #475467;
        text-align: center;
      }
    </style>
</head>
<body>
    <main class="card">
      <h1>Share a file</h1>
      <p>Upload a file. Add a password for encryption. Link works only once.</p>

      <% if (error) { %>
        <p class="error"><%= error %></p>
      <% } %>

      <form action="/upload" method="post" enctype="multipart/form-data">
        <label for="file">File</label>
        <input type="file" id="file" name="file" required />

        <label for="password">Password (optional)</label>
        <input type="password" id="password" name="password" />

        <button type="submit">Upload</button>
      </form>

      <% if (fileLink) { %>
        <div class="link-box">
          <strong>Share this link:</strong>
          <a id="share-link" href="<%= fileLink %>"><%= fileLink %></a>
          <div class="link-actions">
            <button id="copy-link-btn" type="button">Copy Link</button>
            <span id="copy-status" class="copy-status" aria-live="polite"></span>
          </div>
        </div>
      <% } %>

      <footer class="footer">Developer: Joy G. Majumdar</footer>
    </main>

    <% if (fileLink) { %>
      <script>
        (function () {
          var button = document.getElementById("copy-link-btn");
          var link = document.getElementById("share-link");
          var status = document.getElementById("copy-status");

          if (!button || !link || !status) return;

          function setStatus(message) {
            status.textContent = message;
          }

          button.addEventListener("click", async function () {
            try {
              if (navigator.clipboard && navigator.clipboard.writeText) {
                await navigator.clipboard.writeText(link.href);
              } else {
                var tempInput = document.createElement("input");
                tempInput.value = link.href;
                document.body.appendChild(tempInput);
                tempInput.select();
                document.execCommand("copy");
                document.body.removeChild(tempInput);
              }
              setStatus("Link copied.");
            } catch (error) {
              setStatus("Copy failed. Please copy manually.");
            }
          });
        })();
      </script>
    <% } %>
</body>
</html>
